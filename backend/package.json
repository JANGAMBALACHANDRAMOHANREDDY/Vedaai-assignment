{
  "name": "assessment-creator-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/index.js\"",
    "worker": "nodemon --watch src --ext ts --exec \"npm run build && node dist/workers/generation.worker.js\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/generation.worker.js"
  },
  "dependencies": {
    "bullmq": "^5.34.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "mongoose": "^8.9.3",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0",
    "pdf-parse": "^1.1.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
